{% import "@/layouts/AppLayout.jinja" as AppLayout %}
{% import "@/components/ui/Button.jinja" as Button %}
{% import "@/components/ui/Card.jinja" as Card %}
{% import "@/components/ui/StatusBadge.jinja" as StatusBadge %}

{% component DashboardPage %}

  {% props
    user: Optional[dict] = None,
    stats: list = [],
    notifications: list = []
  %}

  <AppLayout title="Dashboard" theme="dark">
    <Card title="Resumo">
      <If when="user">
        <div class="hero">
          <h2>Ola, {{ user.name }}</h2>
          <p jx-text="user.role"></p>
          <StatusBadge status="{{ user.status }}" />
        </div>

        <Else>
          <p>Carregando usuario...</p>
        </Else>
      </If>
    </Card>

    <Card title="Metricas">
      <ul class="stats-grid">
        <For each="stats" as="stat" index="i">
          <li class="stat-card" jx-class='{"stat-card-first": i == 0}'>
            <strong>{{ stat.label }}</strong>
            <span jx-text="stat.value"></span>
          </li>

          <Empty>
            <li>Nenhuma metrica disponivel.</li>
          </Empty>
        </For>
      </ul>
    </Card>

    <Card title="Alertas">
      {% slot footer %}
        <Button variant="secondary" tooltip="Atualiza a lista de alertas">
          Atualizar alertas
        </Button>
      {% endslot %}

      {% for notification in notifications %}
        <article jx-show="notification.visible">
          <h3>{{ notification.title }}</h3>
          <p>{{ notification.message }}</p>
        </article>
      {% else %}
        <p>Sem alertas no momento.</p>
      {% endfor %}
    </Card>
  </AppLayout>
{% endcomponent %}

{% import "@/layouts/AppLayout.jinja" as AppLayout %}
{% import "@/components/ui/Card.jinja" as Card %}
{% import "@/components/ui/ForEach.jinja" as ForEach %}
{% import "@/components/ui/StatusBadge.jinja" as StatusBadge %}

{% component StatusOverview %}

  {% props
    status: str,
    jobs: list = []
  %}

  <AppLayout title="Status Overview" theme="light">
    <Card title="Status do ambiente">
      <Switch value="status">
        <Case when="'draft'">
          <p>Ambiente em rascunho.</p>
        </Case>

        <Case when="'building'">
          <p>Build em andamento.</p>
        </Case>

        <Case when="'ready'">
          <p>Ambiente pronto.</p>
        </Case>

        <Default>
          <p>Status desconhecido.</p>
        </Default>
      </Switch>

      <p>
        Status atual:
        <StatusBadge status="{{ status }}" />
      </p>

      <ul>
        <ForEach items="{{ jobs }}">
          {% slot item(value, index) %}
            <li>
              <span>{{ index + 1 }}. {{ value.name }}</span>
              <StatusBadge status="{{ value.status }}" />
              <span jx-html="value.badge_html"></span>
            </li>
          {% endslot %}

          {% slot empty %}
            <li>Nenhum job registrado.</li>
          {% endslot %}
        </ForEach>
      </ul>
    </Card>
  </AppLayout>
{% endcomponent %}

{% import css "/static/css/components/ui/icon.css" %}

{% component Icon %}

  {% props
    name: Literal[
      "sparkles",
      "layout",
      "blocks",
      "workflow",
      "activity",
      "table",
      "list",
      "sun",
      "moon",
      "mail",
      "shield-check",
      "circle-alert",
      "info",
      "server",
      "database",
      "terminal",
      "arrow-up-right",
      "palette",
      "bolt",
      "x"
    ] = "sparkles",
    size: int = 18,
    stroke_width: float = 1.8
  %}

  {% computed classes %}
    {{ "icon icon-" ~ name }}
  {% endcomputed %}

  <svg
    {{ attrs.render(
      class=classes,
      width=size,
      height=size,
      viewBox="0 0 24 24",
      fill="none",
      xmlns="http://www.w3.org/2000/svg",
      stroke="currentColor",
      stroke_width=stroke_width,
      stroke_linecap="round",
      stroke_linejoin="round",
      aria_hidden="true"
    ) }}
  >
    <Switch value="name">
      <Case when="'sparkles'">
        <path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3z" />
        <path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z" />
        <path d="M5 14l.6 1.7L7.3 16l-1.7.6L5 18.3l-.6-1.7L2.7 16l1.7-.6L5 14z" />
      </Case>

      <Case when="'layout'">
        <rect x="3" y="4" width="18" height="16" rx="3" />
        <path d="M9 4v16" />
        <path d="M9 10h12" />
      </Case>

      <Case when="'blocks'">
        <rect x="4" y="4" width="7" height="7" rx="2" />
        <rect x="13" y="4" width="7" height="7" rx="2" />
        <rect x="4" y="13" width="7" height="7" rx="2" />
        <rect x="13" y="13" width="7" height="7" rx="2" />
      </Case>

      <Case when="'workflow'">
        <circle cx="6" cy="6" r="2" />
        <circle cx="18" cy="6" r="2" />
        <circle cx="12" cy="18" r="2" />
        <path d="M8 6h8" />
        <path d="M7.7 7.3l3.1 7.4" />
        <path d="M16.3 7.3l-3.1 7.4" />
      </Case>

      <Case when="'activity'">
        <path d="M3 12h4l2.5-5 4 10 2.5-5H21" />
      </Case>

      <Case when="'table'">
        <rect x="3" y="4" width="18" height="16" rx="2" />
        <path d="M3 10h18" />
        <path d="M9 4v16" />
        <path d="M15 10v10" />
      </Case>

      <Case when="'list'">
        <path d="M9 6h11" />
        <path d="M9 12h11" />
        <path d="M9 18h11" />
        <path d="M4 6h.01" />
        <path d="M4 12h.01" />
        <path d="M4 18h.01" />
      </Case>

      <Case when="'sun'">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2.5" />
        <path d="M12 19.5V22" />
        <path d="M4.9 4.9l1.8 1.8" />
        <path d="M17.3 17.3l1.8 1.8" />
        <path d="M2 12h2.5" />
        <path d="M19.5 12H22" />
        <path d="M4.9 19.1l1.8-1.8" />
        <path d="M17.3 6.7l1.8-1.8" />
      </Case>

      <Case when="'moon'">
        <path d="M20 14.5A7.5 7.5 0 0 1 9.5 4a8.5 8.5 0 1 0 10.5 10.5z" />
      </Case>

      <Case when="'mail'">
        <rect x="3" y="5" width="18" height="14" rx="2" />
        <path d="M3 7l9 6 9-6" />
      </Case>

      <Case when="'shield-check'">
        <path d="M12 3l7 3v5c0 4.2-2.5 7.9-7 10-4.5-2.1-7-5.8-7-10V6l7-3z" />
        <path d="M9.5 12.5l1.8 1.8 3.7-4" />
      </Case>

      <Case when="'circle-alert'">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 8v5" />
        <path d="M12 16h.01" />
      </Case>

      <Case when="'info'">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 10v6" />
        <path d="M12 7h.01" />
      </Case>

      <Case when="'server'">
        <rect x="4" y="4" width="16" height="7" rx="2" />
        <rect x="4" y="13" width="16" height="7" rx="2" />
        <path d="M8 7h.01" />
        <path d="M8 16h.01" />
        <path d="M12 7h4" />
        <path d="M12 16h4" />
      </Case>

      <Case when="'database'">
        <ellipse cx="12" cy="6" rx="7" ry="3" />
        <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6" />
        <path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
      </Case>

      <Case when="'terminal'">
        <rect x="3" y="4" width="18" height="16" rx="3" />
        <path d="M8 9l3 3-3 3" />
        <path d="M13 15h4" />
      </Case>

      <Case when="'arrow-up-right'">
        <path d="M7 17L17 7" />
        <path d="M9 7h8v8" />
      </Case>

      <Case when="'palette'">
        <path d="M12 4a8 8 0 1 0 0 16h1.2a1.8 1.8 0 0 0 0-3.6H12a2.4 2.4 0 0 1 0-4.8h2.8A5.2 5.2 0 0 0 12 4z" />
        <path d="M7.5 11h.01" />
        <path d="M9.5 8h.01" />
        <path d="M14.5 8h.01" />
        <path d="M16.5 11h.01" />
      </Case>

      <Case when="'bolt'">
        <path d="M13 2L6 13h5l-1 9 7-11h-5l1-9z" />
      </Case>

      <Case when="'x'">
        <path d="M6 6l12 12" />
        <path d="M18 6L6 18" />
      </Case>
    </Switch>
  </svg>
{% endcomponent %}

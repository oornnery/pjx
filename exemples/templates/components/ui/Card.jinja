{% import css "/static/css/components/ui/card.css" %}

{% component Card %}

  {% props
    title: Optional[str] = None,
    bordered: bool = true
  %}

  {% slot header %}{% endslot %}
  {% slot footer %}{% endslot %}

  <section {{ attrs.render(class="card" ~ (" card-bordered" if bordered else "")) }}>
    <header class="card-header">
      {{ slot.header or title }}
    </header>

    <div class="card-body">
      {{ content }}
    </div>

    <footer class="card-footer">
      {{ slot.footer }}
    </footer>
  </section>
{% endcomponent %}

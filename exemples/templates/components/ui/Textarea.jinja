{% import css "/static/css/components/ui/input.css" %}

{% component Textarea %}

  {% props
    name: str,
    value: str = "",
    rows: int = 5,
    placeholder: Optional[str] = None,
    invalid: bool = false,
    disabled: bool = false,
    id: Optional[str] = None
  %}

  {% computed classes %}
    {{ "textarea textarea-invalid" if invalid else "textarea" }}
  {% endcomputed %}

  <textarea
    {{ attrs.render(
      id=id or name,
      name=name,
      rows=rows,
      placeholder=placeholder,
      class=classes,
      disabled=disabled,
      aria_invalid="true" if invalid else None
    ) }}
  >{{ value }}</textarea>
{% endcomponent %}

{% import css "/static/css/components/ui/accordion.css" %}

{% component Accordion %}

  {% props
    title: str,
    summary: Optional[str] = None,
    open: bool = false
  %}

  <details {{ attrs.render(class="accordion", open=open) }}>
    <summary class="accordion-summary">
      <span class="accordion-copy">
        <strong>{{ title }}</strong>
        <If when="summary">
          <span>{{ summary }}</span>
        </If>
      </span>
      <span class="accordion-indicator" aria-hidden="true"></span>
    </summary>

    <div class="accordion-body">
      {{ content }}
    </div>
  </details>
{% endcomponent %}

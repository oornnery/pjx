{% import css "/static/css/components/ui/hover-card.css" %}
{% import "components/ui/Icon.jinja" as Icon %}

{% component HoverCard %}

  {% props
    title: str,
    summary: str,
    eyebrow: str = "Hover",
    icon: str = "sparkles"
  %}

  {% slot trigger %}{% endslot %}

  <div
    {{ attrs.render(class="hover-card") }}
    x-data="{ open: false }"
    x-on:mouseenter="open = true"
    x-on:mouseleave="open = false"
    x-on:focusin="open = true"
    x-on:focusout="open = false"
  >
    <div class="hover-card-trigger">
      {{ slot.trigger or title }}
    </div>

    <article class="hover-card-panel" x-cloak x-show="open" x-transition.opacity.scale.95.origin.top.left>
      <header class="hover-card-header">
        <span class="hover-card-icon">
          <Icon name="{{ icon }}" size="{{ 16 }}" />
        </span>
        <div>
          <p class="hover-card-eyebrow">{{ eyebrow }}</p>
          <h3>{{ title }}</h3>
        </div>
      </header>

      <p class="hover-card-summary">{{ summary }}</p>
      <div class="hover-card-body">
        {{ content }}
      </div>
    </article>
  </div>
{% endcomponent %}

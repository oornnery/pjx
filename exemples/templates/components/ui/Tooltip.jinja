{% import css "/static/css/components/ui/tooltip.css" %}

{% component Tooltip %}

  {% props
    text: str,
    side: Literal["top", "bottom"] = "top"
  %}

  {% computed classes %}
    {{ "tooltip tooltip-" ~ side }}
  {% endcomputed %}

  <span
    {{ attrs.render(class=classes) }}
    x-data="{ open: false }"
    x-on:mouseenter="open = true"
    x-on:mouseleave="open = false"
    x-on:focusin="open = true"
    x-on:focusout="open = false"
  >
    <span class="tooltip-trigger">
      {{ content }}
    </span>

    <span class="tooltip-panel" role="tooltip" x-cloak x-show="open" x-transition.opacity>
      {{ text }}
    </span>
  </span>
{% endcomponent %}

{% import css "/static/css/components/ui/modal.css" %}
{% import "components/ui/Button.jinja" as Button %}
{% import "components/ui/Icon.jinja" as Icon %}

{% component Modal %}

  {% props
    title: str,
    description: Optional[str] = None,
    trigger_label: str = "Open modal",
    trigger_variant: Literal["default", "secondary", "outline", "ghost"] = "secondary",
    size: Literal["sm", "md", "lg"] = "md",
    open: bool = false
  %}

  {% slot footer %}{% endslot %}
  {% slot trigger %}{% endslot %}

  {% computed panel_classes %}
    {{ "modal-panel modal-panel-" ~ size }}
  {% endcomputed %}

  <div
    class="modal-root"
    jx-bind:data-open-default="'true' if open else 'false'"
    x-data="{ open: false }"
    x-init="open = $el.dataset.openDefault === 'true'"
    x-on:keydown.escape.window="open = false"
  >
    <If when="slot.trigger">
      <span
        class="modal-trigger-shell"
        role="button"
        tabindex="0"
        x-on:click="open = true"
        x-on:keydown.enter.prevent="open = true"
        x-on:keydown.space.prevent="open = true"
      >
        {{ slot.trigger }}
      </span>

      <Else>
        <Button variant="{{ trigger_variant }}" type="button" x-on:click="open = true">
          <Icon name="shield-check" size="{{ 16 }}" />
          {{ trigger_label }}
        </Button>
      </Else>
    </If>

    <div
      class="modal-portal"
      x-cloak
      x-show="open"
      x-transition.opacity
      x-bind:aria-hidden="(!open).toString()"
    >
      <div class="modal-backdrop" x-on:click="open = false"></div>

      <div class="modal-frame">
        <article class="{{ panel_classes }}" role="dialog" aria-modal="true" x-on:click.stop>
          <header class="modal-header">
            <div class="modal-copy">
              <p class="modal-kicker">Modal</p>
              <h3>{{ title }}</h3>
              <If when="description">
                <p class="modal-description">{{ description }}</p>
              </If>
            </div>

            <button class="modal-close" type="button" x-on:click="open = false" aria-label="Close modal">
              <Icon name="x" size="{{ 16 }}" />
            </button>
          </header>

          <div class="modal-body">
            {{ content }}
          </div>

          <footer class="modal-footer">
            <If when="slot.footer">
              {{ slot.footer }}

              <Else>
                <Button variant="ghost" type="button" x-on:click="open = false">
                  Close
                </Button>
              </Else>
            </If>
          </footer>
        </article>
      </div>
    </div>
  </div>
{% endcomponent %}

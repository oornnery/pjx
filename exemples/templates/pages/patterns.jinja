{% import css "/static/css/pages/patterns.css" %}
{% import "layouts/AppLayout.jinja" as AppLayout %}
{% import "components/ui/Button.jinja" as Button %}
{% import "components/ui/Card.jinja" as Card %}
{% import "components/ui/Checkbox.jinja" as Checkbox %}
{% import "components/ui/ForEach.jinja" as ForEach %}
{% import "components/ui/HoverCard.jinja" as HoverCard %}
{% import "components/ui/Icon.jinja" as Icon %}
{% import "components/ui/Select.jinja" as Select %}
{% import "components/ui/StatusBadge.jinja" as StatusBadge %}
{% import "components/ui/Switch.jinja" as ToggleSwitch %}
{% import "components/ui/ThemePanel.jinja" as ThemePanel %}
{% import "components/ui/Accordion.jinja" as Accordion %}
{% import "components/ui/Tooltip.jinja" as Tooltip %}

{% component PatternsPage %}

  {% props
    team: list = [],
    snippets: list = [],
    state_card: dict = {},
    attrs_demo: dict = {},
    interactive_demo: dict = {},
    accordion_examples: list = [],
    tooltip_examples: list = [],
    hover_examples: list = []
  %}

  <AppLayout title="Component Patterns" theme="light">
    <section class="patterns-shell" x-data="{ showSnippet: true, localTone: 'warm' }">
      <div class="patterns-grid">
        <ThemePanel
          title="Provide / inject"
          eyebrow="Context propagation"
          icon="palette"
          tone="warm"
          class="patterns-panel"
          tooltip="AppLayout fornece theme; ThemePanel consome isso automaticamente"
        >
          <p>
            Esse componente nao recebe `theme` via props. O valor vem do layout,
            mostrando o fluxo de contexto sem prop drilling.
          </p>

          <div class="patterns-tone-row">
            <button class="patterns-tone-chip" x-on:click="localTone = 'calm'">
              <Icon name="activity" size="{{ 14 }}" />
              <span>Calm</span>
            </button>
            <button class="patterns-tone-chip" x-on:click="localTone = 'warm'">
              <Icon name="sparkles" size="{{ 14 }}" />
              <span>Warm</span>
            </button>
            <button class="patterns-tone-chip" x-on:click="localTone = 'hot'">
              <Icon name="bolt" size="{{ 14 }}" />
              <span>Hot</span>
            </button>
          </div>

          <div class="patterns-tone-preview" x-bind:data-tone="localTone">
            <strong x-text="localTone"></strong>
            <span>Alpine melhora a UX local sem tirar o servidor do centro.</span>
          </div>
        </ThemePanel>

        <Card title="Server directives" class="patterns-card">
          <article
            class="patterns-state-card"
            jx-class='{"patterns-state-card-active": state_card.active}'
          >
            <div class="patterns-state-head">
              <h3 jx-text="state_card.title"></h3>
              <StatusBadge status="{{ state_card.status }}" />
            </div>

            <p>{{ state_card.summary }}</p>
            <div class="patterns-state-html" jx-html="state_card.badge_html"></div>
            <p class="patterns-state-note" jx-show="state_card.note_visible">
              {{ state_card.note }}
            </p>
          </article>
        </Card>
      </div>

      <div class="patterns-grid">
        <Card title="Scoped slots" class="patterns-card">
          <ForEach items="{{ team }}">
            {% slot item(value, index) %}
              <article class="patterns-person-row">
                <div>
                  <strong>{{ index + 1 }}. {{ value.name }}</strong>
                  <p>{{ value.role }}</p>
                </div>
                <StatusBadge status="{{ value.status }}" />
              </article>
            {% endslot %}

            {% slot empty %}
              <p>Nenhum membro registrado.</p>
            {% endslot %}
          </ForEach>
        </Card>

        <Card title="Attrs passthrough" class="patterns-card">
          <ThemePanel
            title="{{ attrs_demo.title }}"
            eyebrow="Attrs.render"
            icon="server"
            tone="calm"
            class="patterns-attrs-demo"
            data_variant="{{ attrs_demo.variant }}"
          >
            <p>{{ attrs_demo.summary }}</p>
            <Button
              variant="secondary"
              tooltip="{{ attrs_demo.tooltip }}"
              x-data="{ open: false }"
              x-on:focus="open = true"
              x-on:blur="open = false"
              x-bind:data-active="open ? 'true' : 'false'"
            >
              <Icon name="arrow-up-right" size="{{ 16 }}" />
              Attrs livres, sem boilerplate
            </Button>
          </ThemePanel>
        </Card>
      </div>

      <div class="patterns-grid">
        <Card title="Interactive primitives" class="patterns-card">
          <div
            class="patterns-controls-shell"
            x-data="{
              density: 'comfortable',
              showMetrics: true,
              pinSidebar: false
            }"
          >
            <div class="patterns-controls-grid">
              <Select
                name="patterns-density"
                value="comfortable"
                options="{{ interactive_demo.densities }}"
                x-model="density"
              />

              <ToggleSwitch
                name="patterns-metrics"
                value="metrics"
                checked="{{ true }}"
                x-model="showMetrics"
              >
                Mostrar metricas densas
              </ToggleSwitch>

              <Checkbox
                name="patterns-sidebar"
                value="sidebar"
                x-model="pinSidebar"
              >
                Sidebar fixa no layout
              </Checkbox>
            </div>

            <div class="patterns-interactive-preview">
              <strong>Preview local</strong>
              <p>
                Density:
                <span x-text="density"></span>
                · Metrics:
                <span x-text="showMetrics ? 'on' : 'off'"></span>
                · Sidebar:
                <span x-text="pinSidebar ? 'pinned' : 'floating'"></span>
              </p>
            </div>
          </div>
        </Card>

        <Card title="Accordion / disclosure" class="patterns-card">
          <div class="patterns-accordion-stack">
            <For each="accordion_examples" as="item">
              <Accordion
                title="{{ item.title }}"
                summary="{{ item.summary }}"
                open="{{ item.open }}"
              >
                <ul class="patterns-accordion-list">
                  <For each="item.points" as="point">
                    <li>{{ point }}</li>
                  </For>
                </ul>
              </Accordion>
            </For>
          </div>
        </Card>
      </div>

      <div class="patterns-grid">
        <Card title="Hover and tooltip" class="patterns-card">
          <div class="patterns-hover-tooltip-shell">
            <div class="patterns-tooltip-row">
              <For each="tooltip_examples" as="item">
                <Tooltip text="{{ item.description }}">
                  <button class="patterns-tone-chip" type="button">
                    <Icon name="{{ item.icon }}" size="{{ 14 }}" />
                    <span>{{ item.label }}</span>
                  </button>
                </Tooltip>
              </For>
            </div>

            <div class="patterns-hover-grid">
              <For each="hover_examples" as="item">
                <HoverCard
                  title="{{ item.title }}"
                  summary="{{ item.summary }}"
                  eyebrow="{{ item.eyebrow }}"
                  icon="{{ item.icon }}"
                >
                  {% slot trigger %}
                    <button class="patterns-hover-trigger" type="button">
                      <Icon name="{{ item.icon }}" size="{{ 14 }}" />
                      <span>{{ item.trigger }}</span>
                    </button>
                  {% endslot %}

                  <ul class="patterns-hover-list">
                    <For each="item.points" as="point">
                      <li>{{ point }}</li>
                    </For>
                  </ul>
                </HoverCard>
              </For>
            </div>
          </div>
        </Card>

        <ThemePanel
          title="Hover states bem completos"
          eyebrow="Interaction polish"
          icon="sparkles"
          tone="calm"
          class="patterns-panel"
        >
          <p>
            O objetivo aqui e cobrir o espectro inteiro: tooltip para contexto curto,
            hover card para contexto denso e modal quando a tarefa merece foco exclusivo.
          </p>

          <div class="patterns-hover-notes">
            <div class="patterns-interactive-preview">
              <strong>Tooltip</strong>
              <p>Explica acao, status ou token sem abrir outra camada visual.</p>
            </div>
            <div class="patterns-interactive-preview">
              <strong>Hover card</strong>
              <p>Entrega metadado mais rico sem interromper o ritmo do usuario.</p>
            </div>
          </div>
        </ThemePanel>
      </div>

      <Card title="Template snippets">
        <div class="patterns-snippet-actions">
          <button class="patterns-toggle" x-on:click="showSnippet = !showSnippet">
            Alternar bloco
          </button>
        </div>

        <div class="patterns-snippet-list" x-show="showSnippet">
          <For each="snippets" as="snippet">
            <article class="patterns-snippet-card">
              <div class="patterns-snippet-head">
                <div class="patterns-snippet-title">
                  <span class="patterns-snippet-icon">
                    <Icon name="{{ snippet.icon }}" size="{{ 15 }}" />
                  </span>
                  <strong>{{ snippet.title }}</strong>
                </div>
                <span>{{ snippet.kind }}</span>
              </div>
              <p>{{ snippet.description }}</p>
              <pre>{{ snippet.code }}</pre>
            </article>
          </For>
        </div>
      </Card>
    </section>
  </AppLayout>
{% endcomponent %}

{% import css "/static/css/pages/catalog.css" %}
{% import "layouts/AppLayout.jinja" as AppLayout %}
{% import "components/ui/Card.jinja" as Card %}
{% import "components/ui/Icon.jinja" as Icon %}
{% import "components/ui/StatusBadge.jinja" as StatusBadge %}

{% component CatalogPage %}

  {% props
    stats: dict = {},
    entries: list = []
  %}

  <AppLayout title="Component Catalog" theme="light">
    <section class="catalog-shell">
      <div class="catalog-stats-grid">
        <Card title="Templates" class="catalog-stat-card">
          <span class="catalog-stat-icon">
            <Icon name="layout" size="{{ 18 }}" />
          </span>
          <strong class="catalog-stat-value">{{ stats.total }}</strong>
          <p>Arquivos `.jinja` registrados no catalog.</p>
        </Card>

        <Card title="Com slots" class="catalog-stat-card">
          <span class="catalog-stat-icon">
            <Icon name="workflow" size="{{ 18 }}" />
          </span>
          <strong class="catalog-stat-value">{{ stats.with_slots }}</strong>
          <p>Templates com slots nomeados ou scoped slots.</p>
        </Card>

        <Card title="Com assets" class="catalog-stat-card">
          <span class="catalog-stat-icon">
            <Icon name="database" size="{{ 18 }}" />
          </span>
          <strong class="catalog-stat-value">{{ stats.with_assets }}</strong>
          <p>Componentes que registram CSS ou JS no topo do arquivo.</p>
        </Card>
      </div>

      <div class="catalog-list">
        <For each="entries" as="entry">
          <Card class="catalog-entry-card">
            {% slot header %}
              <div class="catalog-entry-head">
                <div>
                  <p class="catalog-entry-path">{{ entry.template }}</p>
                  <div class="catalog-entry-title-row">
                    <span class="catalog-entry-icon">
                      <Icon name="blocks" size="{{ 16 }}" />
                    </span>
                    <strong>{{ entry.component }}</strong>
                  </div>
                </div>
                <StatusBadge status="{{ entry.status }}" />
              </div>
            {% endslot %}

            <div class="catalog-meta-grid">
              <div>
                <p class="catalog-meta-label">Required</p>
                <ul>
                  <For each="entry.required" as="item">
                    <li>{{ item }}</li>
                    <Empty>
                      <li>none</li>
                    </Empty>
                  </For>
                </ul>
              </div>

              <div>
                <p class="catalog-meta-label">Optional</p>
                <ul>
                  <For each="entry.optional" as="item">
                    <li>{{ item }}</li>
                    <Empty>
                      <li>none</li>
                    </Empty>
                  </For>
                </ul>
              </div>

              <div>
                <p class="catalog-meta-label">Slots</p>
                <ul>
                  <For each="entry.slots" as="item">
                    <li>{{ item }}</li>
                    <Empty>
                      <li>none</li>
                    </Empty>
                  </For>
                </ul>
              </div>
            </div>

            <div class="catalog-asset-row">
              <div>
                <p class="catalog-meta-label">CSS</p>
                <For each="entry.css" as="asset">
                  <code>{{ asset }}</code>
                  <Empty>
                    <code>none</code>
                  </Empty>
                </For>
              </div>

              <div>
                <p class="catalog-meta-label">JS</p>
                <For each="entry.js" as="asset">
                  <code>{{ asset }}</code>
                  <Empty>
                    <code>none</code>
                  </Empty>
                </For>
              </div>
            </div>
          </Card>
        </For>
      </div>
    </section>
  </AppLayout>
{% endcomponent %}

{% import css "/static/layouts/app-layout.css" %}

{% component AppLayout %}

  {% props
    title: str,
    theme: str = "light"
  %}

  {% provide theme %}

  <div class="app-layout" data-theme="{{ theme }}">
    <header class="app-header">
      <div>
        <p class="app-eyebrow">PJX Example</p>
        <h1>{{ title }}</h1>
      </div>
    </header>

    <main class="app-main">
      {{ content }}
    </main>
  </div>
{% endcomponent %}

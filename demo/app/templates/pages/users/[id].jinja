---
from ...layouts import BaseLayout
from ...icons import IconUser, IconEdit, IconTrash

vars:
  meta_style: "font-size: 0.85rem; color: #9ca3af;"
  email_style: "margin: 1rem 0; color: #6b7280;"

computed:
  is_admin: props.user.role == "admin"
  badge_class: cn("badge", "badge-admin" if is_admin else "badge-user")
  user_url: "/users/" ~ props.user.id
---

<BaseLayout title={props.user.name}>
  <div class="card" style="max-width: 500px;">
    <h2>
      <IconUser size="24" />
      {{ props.user.name }}
      <span class={badge_class}>
        <Show when={is_admin}>admin<Else>{{ props.user.role }}</Else></Show>
      </span>
    </h2>

    <p style={email_style}>{{ props.user.email }}</p>
    <p style={meta_style}>ID: {{ props.user.id }}</p>

    <div class="card-actions" style="margin-top: 1.5rem;">
      <a href="/" class="btn btn-sm">Voltar</a>
      <button
        class="btn btn-sm"
        htmx:get={user_url ~ "/edit"}
        htmx:target="#modal-container"
        htmx:swap="innerHTML">
        <IconEdit size="14" />
        Editar
      </button>
      <button
        class="btn btn-danger btn-sm"
        htmx:delete={user_url}
        htmx:confirm="Remover este usuario?"
        htmx:on="htmx:afterOnLoad: window.location='/'">
        <IconTrash size="14" />
        Remover
      </button>
    </div>
  </div>

  <div id="modal-container"></div>
</BaseLayout>

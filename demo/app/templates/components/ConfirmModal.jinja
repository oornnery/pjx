<div
  class="modal-overlay"
  id="confirm-modal"
  stimulus:controller="modal"
  style="display:none;">
  <div class="modal-box">
    <p class="modal-message" stimulus:target="message"></p>
    <div class="modal-actions">
      <button class="btn btn-sm" stimulus:action="click->modal#cancel">Cancelar</button>
      <button class="btn btn-danger btn-sm" stimulus:action="click->modal#confirm">Confirmar</button>
    </div>
  </div>
</div>

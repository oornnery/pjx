---
import Layout from "../layouts/Base.jinja"
---

<Layout>
  <VStack gap="1rem" class="page" style="text-align: center;">
    <div>
      <h1>Live Clock</h1>
      <p>Real-time server clock via SSE — the time streams from the backend every second.</p>
    </div>
    <Center>
      <div live="/sse/clock" channel="clock">
        {{ clock }}
      </div>
    </Center>
  </VStack>
</Layout>

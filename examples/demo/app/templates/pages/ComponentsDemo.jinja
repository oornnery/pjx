---
import Layout from "../layouts/Basecoat.jinja"
---

<Layout>
  <div style="display: flex; flex-direction: column; gap: 2.5rem; padding-bottom: 2rem;">

    <!-- Page Header -->
    <div>
      <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem;">Basecoat UI Components</h1>
      <p style="color: var(--muted-foreground);">
        All components from <strong>basecoat-css</strong> installed via
        <code style="background: var(--muted); padding: 0.15em 0.4em; border-radius: 0.25rem; font-size: 0.875em;">pjx add basecoat-css</code>.
      </p>
    </div>

    <!-- ─── Buttons ──────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Buttons</h2>
        <p>All button variants and sizes.</p>
      </header>
      <section style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          <button class="btn">Primary</button>
          <button class="btn-secondary">Secondary</button>
          <button class="btn-destructive">Destructive</button>
          <button class="btn-outline">Outline</button>
          <button class="btn-ghost">Ghost</button>
          <a href="#" class="btn-link">Link</a>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
          <button class="btn-lg">Large</button>
          <button class="btn">Default</button>
          <button class="btn-sm">Small</button>
          <button class="btn-icon-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
          </button>
        </div>
        <div style="display: flex; gap: 0.5rem;">
          <button class="btn" disabled>Disabled</button>
          <button class="btn-outline" disabled>Disabled</button>
        </div>
      </section>
    </div>

    <!-- ─── Badges ───────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Badges</h2>
        <p>Status indicators and labels.</p>
      </header>
      <section>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          <span class="badge">Default</span>
          <span class="badge-secondary">Secondary</span>
          <span class="badge-destructive">Destructive</span>
          <span class="badge-outline">Outline</span>
        </div>
      </section>
    </div>

    <!-- ─── Alerts ───────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Alerts</h2>
        <p>Contextual feedback messages.</p>
      </header>
      <section style="display: flex; flex-direction: column; gap: 1rem;">
        <div class="alert">
          <h2>Heads up!</h2>
          <section>You can add components to your app using the CLI.</section>
        </div>
        <div class="alert-destructive">
          <h2>Error</h2>
          <section>Your session has expired. Please log in again.</section>
        </div>
      </section>
    </div>

    <!-- ─── Cards ────────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Cards</h2>
        <p>Containers for grouped content.</p>
      </header>
      <section>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem;">
          <div class="card">
            <header>
              <h2>Total Revenue</h2>
              <p>January - March 2026</p>
            </header>
            <section>
              <p style="font-size: 2rem; font-weight: 700; line-height: 1.2;">$45,231.89</p>
              <p style="color: var(--muted-foreground); margin-top: 0.25rem;">+20.1% from last month</p>
            </section>
          </div>
          <div class="card">
            <header>
              <h2>Active Users</h2>
              <p>Currently online</p>
            </header>
            <section>
              <p style="font-size: 2rem; font-weight: 700; line-height: 1.2;">+2,350</p>
              <p style="color: var(--muted-foreground); margin-top: 0.25rem;">+180 since last hour</p>
            </section>
          </div>
          <div class="card">
            <header>
              <h2>Components</h2>
              <p>Installed via PJX</p>
            </header>
            <section>
              <p style="font-size: 2rem; font-weight: 700; line-height: 1.2;">39</p>
              <p style="color: var(--muted-foreground); margin-top: 0.25rem;">All from basecoat-css</p>
            </section>
          </div>
        </div>
      </section>
    </div>

    <!-- ─── Form Inputs ──────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Form Inputs</h2>
        <p>Text fields, selects, checkboxes, switches, and more.</p>
      </header>
      <section>
        <form onsubmit="return false" style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem;">
            <div style="display: flex; flex-direction: column; gap: 0.375rem;">
              <label class="label" for="demo-name">Name</label>
              <input class="input" id="demo-name" type="text" placeholder="Enter your name" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.375rem;">
              <label class="label" for="demo-email">Email</label>
              <input class="input" id="demo-email" type="email" placeholder="name@example.com" />
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 0.375rem;">
            <label class="label" for="demo-bio">Bio</label>
            <textarea class="textarea" id="demo-bio" rows="3" placeholder="Tell us about yourself"></textarea>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem;">
            <fieldset style="border: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              <legend class="label" style="margin-bottom: 0.125rem;">Plan</legend>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                <input type="radio" class="radio" name="plan" value="free" checked />
                Free
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                <input type="radio" class="radio" name="plan" value="pro" />
                Pro
              </label>
            </fieldset>
            <fieldset style="border: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              <legend class="label" style="margin-bottom: 0.125rem;">Preferences</legend>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                <input type="checkbox" class="checkbox" checked />
                Email notifications
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                <input type="checkbox" class="switch" />
                Dark mode
              </label>
            </fieldset>
          </div>

          <div style="display: flex; flex-direction: column; gap: 0.375rem;">
            <label class="label" for="demo-invalid">Invalid field</label>
            <input class="input" id="demo-invalid" type="text" value="bad input" aria-invalid="true" />
            <p style="color: var(--destructive); font-size: 0.8125rem;">This field is required.</p>
          </div>

          <div style="display: flex; gap: 0.5rem;">
            <button class="btn" type="submit">Submit</button>
            <button class="btn-outline" type="reset">Reset</button>
          </div>
        </form>
      </section>
    </div>

    <!-- ─── Dialog ───────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Dialog</h2>
        <p>Modal dialogs using native HTML <code style="background: var(--muted); padding: 0.15em 0.4em; border-radius: 0.25rem; font-size: 0.875em;">&lt;dialog&gt;</code>.</p>
      </header>
      <section>
        <button class="btn-outline" onclick="document.getElementById('demo-dialog').showModal()">
          Open Dialog
        </button>

        <dialog id="demo-dialog" class="dialog"
                aria-labelledby="demo-dialog-title"
                aria-describedby="demo-dialog-desc"
                onclick="if (event.target === this) this.close()">
          <div>
            <header>
              <h2 id="demo-dialog-title">Are you sure?</h2>
              <p id="demo-dialog-desc">This action cannot be undone. This will permanently delete your account.</p>
            </header>
            <footer style="display: flex; justify-content: flex-end; gap: 0.5rem;">
              <button class="btn-outline" onclick="this.closest('dialog').close()">Cancel</button>
              <button class="btn-destructive" onclick="this.closest('dialog').close()">Delete Account</button>
            </footer>
            <button type="button" aria-label="Close dialog" onclick="this.closest('dialog').close()"
                    style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; cursor: pointer; color: var(--muted-foreground);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
          </div>
        </dialog>
      </section>
    </div>

    <!-- ─── Tabs ─────────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Tabs</h2>
        <p>Tabbed content navigation.</p>
      </header>
      <section>
        <div class="tabs" id="demo-tabs">
          <nav role="tablist" aria-orientation="horizontal">
            <button type="button" role="tab" id="demo-tabs-tab-account"
                    aria-controls="demo-tabs-panel-account" aria-selected="true" tabindex="0">
              Account
            </button>
            <button type="button" role="tab" id="demo-tabs-tab-password"
                    aria-controls="demo-tabs-panel-password" aria-selected="false" tabindex="0">
              Password
            </button>
            <button type="button" role="tab" id="demo-tabs-tab-settings"
                    aria-controls="demo-tabs-panel-settings" aria-selected="false" tabindex="0">
              Settings
            </button>
          </nav>
          <div role="tabpanel" id="demo-tabs-panel-account"
               aria-labelledby="demo-tabs-tab-account" tabindex="-1" aria-selected="true">
            <div style="display: flex; flex-direction: column; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card);">
              <div>
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.125rem;">Account</h3>
                <p style="font-size: 0.875rem; color: var(--muted-foreground);">Make changes to your account here.</p>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                  <label class="label" for="tab-name">Name</label>
                  <input class="input" id="tab-name" value="Alice" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                  <label class="label" for="tab-user">Username</label>
                  <input class="input" id="tab-user" value="@alice" />
                </div>
              </div>
              <div>
                <button class="btn">Save changes</button>
              </div>
            </div>
          </div>
          <div role="tabpanel" id="demo-tabs-panel-password"
               aria-labelledby="demo-tabs-tab-password" tabindex="-1" aria-selected="false" hidden>
            <div style="display: flex; flex-direction: column; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card);">
              <div>
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.125rem;">Password</h3>
                <p style="font-size: 0.875rem; color: var(--muted-foreground);">Change your password here.</p>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                  <label class="label" for="tab-current">Current password</label>
                  <input class="input" id="tab-current" type="password" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                  <label class="label" for="tab-new">New password</label>
                  <input class="input" id="tab-new" type="password" />
                </div>
              </div>
              <div>
                <button class="btn">Change password</button>
              </div>
            </div>
          </div>
          <div role="tabpanel" id="demo-tabs-panel-settings"
               aria-labelledby="demo-tabs-tab-settings" tabindex="-1" aria-selected="false" hidden>
            <div style="display: flex; flex-direction: column; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card);">
              <div>
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.125rem;">Settings</h3>
                <p style="font-size: 0.875rem; color: var(--muted-foreground);">Manage your preferences.</p>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                  <input type="checkbox" class="switch" checked />
                  Email notifications
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
                  <input type="checkbox" class="switch" />
                  SMS notifications
                </label>
              </div>
              <div>
                <button class="btn">Save preferences</button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- ─── Progress & Skeleton ──────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Progress &amp; Skeleton</h2>
        <p>Loading indicators.</p>
      </header>
      <section style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label class="label">Upload progress (66%)</label>
          <div style="position: relative; height: 0.5rem; width: 100%; overflow: hidden; border-radius: 9999px; background: color-mix(in oklch, var(--primary) 20%, transparent);">
            <div style="height: 100%; width: 66%; background: var(--primary); border-radius: 9999px; transition: width 0.3s;"></div>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label class="label">Skeleton loading</label>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: var(--accent); animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; flex-shrink: 0;"></div>
            <div style="display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
              <div style="height: 0.75rem; width: 60%; border-radius: 0.375rem; background: var(--accent); animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;"></div>
              <div style="height: 0.75rem; width: 40%; border-radius: 0.375rem; background: var(--accent); animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;"></div>
            </div>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <label class="label">Spinner</label>
          <div style="display: flex; gap: 1rem; align-items: center;">
            <svg style="width: 1.5rem; height: 1.5rem; animation: spin 1s linear infinite; color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="status" aria-label="Loading">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
            </svg>
            <svg style="width: 1rem; height: 1rem; animation: spin 1s linear infinite; color: var(--muted-foreground);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="status" aria-label="Loading">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
            </svg>
          </div>
        </div>
      </section>
    </div>

    <!-- ─── Accordion ────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Accordion</h2>
        <p>Collapsible content sections.</p>
      </header>
      <section>
        <div class="accordion">
          <details>
            <summary>
              <h2 style="display: flex; flex: 1; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 0; font-size: 0.875rem; font-weight: 500; text-align: left;">
                Is it accessible?
                <svg style="width: 1rem; height: 1rem; color: var(--muted-foreground); flex-shrink: 0; transition: transform 0.2s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </h2>
            </summary>
            <section style="padding-bottom: 1rem; font-size: 0.875rem; color: var(--muted-foreground);">
              Yes. It uses native HTML details and summary elements for full accessibility.
            </section>
          </details>
          <details>
            <summary>
              <h2 style="display: flex; flex: 1; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 0; font-size: 0.875rem; font-weight: 500; text-align: left;">
                Is it styled?
                <svg style="width: 1rem; height: 1rem; color: var(--muted-foreground); flex-shrink: 0; transition: transform 0.2s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </h2>
            </summary>
            <section style="padding-bottom: 1rem; font-size: 0.875rem; color: var(--muted-foreground);">
              Yes. It comes with default styles from Basecoat that match the design system.
            </section>
          </details>
          <details>
            <summary>
              <h2 style="display: flex; flex: 1; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 0; font-size: 0.875rem; font-weight: 500; text-align: left;">
                Is it animated?
                <svg style="width: 1rem; height: 1rem; color: var(--muted-foreground); flex-shrink: 0; transition: transform 0.2s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </h2>
            </summary>
            <section style="padding-bottom: 1rem; font-size: 0.875rem; color: var(--muted-foreground);">
              Yes. It includes smooth open/close transitions via CSS.
            </section>
          </details>
        </div>
      </section>
    </div>

    <!-- ─── Table ────────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Table</h2>
        <p>Data display in tabular format.</p>
      </header>
      <section>
        <div class="table">
          <table>
            <thead>
              <tr>
                <th>Invoice</th>
                <th>Status</th>
                <th>Method</th>
                <th style="text-align: right;">Amount</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>INV001</td>
                <td><span class="badge">Paid</span></td>
                <td>Credit Card</td>
                <td style="text-align: right;">$250.00</td>
              </tr>
              <tr>
                <td>INV002</td>
                <td><span class="badge-secondary">Pending</span></td>
                <td>PayPal</td>
                <td style="text-align: right;">$150.00</td>
              </tr>
              <tr>
                <td>INV003</td>
                <td><span class="badge-destructive">Overdue</span></td>
                <td>Bank Transfer</td>
                <td style="text-align: right;">$350.00</td>
              </tr>
              <tr>
                <td>INV004</td>
                <td><span class="badge">Paid</span></td>
                <td>Credit Card</td>
                <td style="text-align: right;">$450.00</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <!-- ─── Avatars ──────────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Avatars</h2>
        <p>User profile images with fallback initials.</p>
      </header>
      <section>
        <div style="display: flex; gap: 0.75rem; align-items: center;">
          <img src="https://api.dicebear.com/9.x/initials/svg?seed=Alice&backgroundColor=6c63ff" alt="Alice"
               style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; object-fit: cover; flex-shrink: 0;" />
          <img src="https://api.dicebear.com/9.x/initials/svg?seed=Bob&backgroundColor=e94560" alt="Bob"
               style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; object-fit: cover; flex-shrink: 0;" />
          <img src="https://api.dicebear.com/9.x/initials/svg?seed=Charlie&backgroundColor=10b981" alt="Charlie"
               style="width: 2.5rem; height: 2.5rem; border-radius: 9999px; object-fit: cover; flex-shrink: 0;" />
          <span style="display: inline-flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: var(--muted); color: var(--muted-foreground); font-size: 0.75rem; font-weight: 600; flex-shrink: 0;">
            AB
          </span>
        </div>
      </section>
    </div>

    <!-- ─── Breadcrumbs ──────────────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Breadcrumbs</h2>
        <p>Navigation path indicators.</p>
      </header>
      <section>
        <nav aria-label="Breadcrumb">
          <ol style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--muted-foreground); list-style: none; padding: 0; margin: 0;">
            <li style="display: inline-flex; align-items: center; gap: 0.375rem;">
              <a href="/" style="color: var(--muted-foreground); text-decoration: none; transition: color 0.15s;">Home</a>
            </li>
            <li style="color: var(--muted-foreground);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </li>
            <li style="display: inline-flex; align-items: center; gap: 0.375rem;">
              <a href="/components" style="color: var(--muted-foreground); text-decoration: none; transition: color 0.15s;">Components</a>
            </li>
            <li style="color: var(--muted-foreground);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </li>
            <li style="display: inline-flex; align-items: center; gap: 0.375rem;">
              <span style="color: var(--foreground); font-weight: 500;">Basecoat</span>
            </li>
          </ol>
        </nav>
      </section>
    </div>

    <!-- ─── Keyboard Shortcuts ───────────────────────────────────────────── -->
    <div class="card">
      <header>
        <h2>Keyboard Shortcuts</h2>
        <p>Display keyboard shortcut hints with kbd.</p>
      </header>
      <section>
        <div style="display: flex; flex-wrap: wrap; gap: 2rem; font-size: 0.875rem;">
          <span>Copy: <kbd class="kbd">Ctrl</kbd> + <kbd class="kbd">C</kbd></span>
          <span>Save: <kbd class="kbd">Ctrl</kbd> + <kbd class="kbd">S</kbd></span>
          <span>Search: <kbd class="kbd">Ctrl</kbd> + <kbd class="kbd">K</kbd></span>
        </div>
      </section>
    </div>

    <!-- ─── Tooltip ──────────────────────────────────────────────────────── -->

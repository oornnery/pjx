---
import Layout from "../layouts/Base.jinja"
---

<Layout>
  <VStack gap="1rem" class="page" style="align-items: center; text-align: center;">
    <div>
      <h1>Search Users</h1>
      <p>HTMX-powered search with 300ms debounce — results swap in without a page reload.</p>
    </div>
    <div class="search">
      <input type="text" name="query"
        action:get="/htmx/search"
        trigger="input changed delay:300ms"
        target="#search-results"
        placeholder="Search by name or email..." />
      <div id="search-results" class="search__results">
        {{ search_results }}
      </div>
    </div>
  </VStack>
</Layout>

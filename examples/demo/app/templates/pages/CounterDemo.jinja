---
import Layout from "../layouts/Base.jinja"
import Counter from "../components/Counter.jinja"
import ServerCounter from "../components/ServerCounter.jinja"
---

<Layout>
  <VStack gap="1rem" class="page page--wide" style="align-items: center;">
    <div>
      <h1>Counter Demo</h1>
      <p>Two ways to manage state — pick the one that fits your use case.</p>
    </div>
    <div class="counter-grid" style="width: 100%;">
      <div class="counter-section">
        <h2>Client-side <span class="badge badge--client">Alpine.js</span></h2>
        <p>State lives in the browser. No server requests — instant updates. Great for local UI state.</p>
        <Counter />
      </div>
      <div class="counter-section">
        <h2>Server-side <span class="badge badge--server">HTMX</span></h2>
        <p>State lives on the server. Each click sends a request and swaps HTML. Great for shared state.</p>
        <ServerCounter count="{{ server_count }}" />
      </div>
    </div>
  </VStack>
</Layout>

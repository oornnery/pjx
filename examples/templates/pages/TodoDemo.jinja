---
import Layout from "../layouts/Base.jinja"
---

<Layout>
  <VStack gap="1.5rem" class="page" x-data="{ filter: 'all' }">
    <h1>Todo List</h1>
    <input type="hidden" id="todo-filter" name="status" bind:value="filter" />
    <form class="todo-add" action:post="/htmx/todos/add" into="#todo-list"
      hx-include="#todo-filter">
      <input type="text" name="text" placeholder="What needs to be done?" required />
      <button type="submit" class="btn btn-primary">Add</button>
    </form>
    <HStack gap="0.5rem" class="todo-filters">
      <button class="btn btn-filter"
        bind:class="filter === 'all' && 'active'"
        on:click="filter = 'all'"
        action:get="/htmx/todos/filter?status=all"
        into="#todo-list">
        All
      </button>
      <button class="btn btn-filter"
        bind:class="filter === 'pending' && 'active'"
        on:click="filter = 'pending'"
        action:get="/htmx/todos/filter?status=pending"
        into="#todo-list">
        Pending
      </button>
      <button class="btn btn-filter"
        bind:class="filter === 'done' && 'active'"
        on:click="filter = 'done'"
        action:get="/htmx/todos/filter?status=done"
        into="#todo-list">
        Done
      </button>
    </HStack>
    <div id="todo-list" class="todo-list">
      {{ todo_list }}
    </div>
  </VStack>
</Layout>
